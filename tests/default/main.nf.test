nextflow_pipeline {

    name "main.nf default smoke test"
    script "../../main.nf"

    test("runs successfully with bundled example inputs") {

        options "-stub-run"

        when {
            params {
                outdir = "results"
            }
        }

        then {
            assert workflow.success
            assert snapshot(
                workflow.exitStatus,
                workflow.trace.succeeded().size(),
                path(params.outdir).list().collect { it.getFileName().toString() }.sort()
            ).match()
        }
    }
}
